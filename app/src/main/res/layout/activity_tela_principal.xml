<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3BA0E2"
        android:padding="16dp"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvLogoMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MyStudent"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F5F5"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvSobreNosTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sobre nós"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#546E7A"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvSobreNosTexto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bem-vindo ao MyStudent! Este sistema foi desenvolvido para facilitar o gerenciamento e cadastro de alunos e seus respectivos cursos de forma rápida e prática."
            android:textSize="16sp"
            android:gravity="center"
            android:textColor="#757575" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnMenuCadAluno"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginRight="4dp"
                android:text="Cadastrar\nAluno"
                android:backgroundTint="#3BA0E2"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnMenuCadCurso"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:text="Cadastrar\nCurso"
                android:backgroundTint="#3BA0E2"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMenuVerAlunos"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginRight="4dp"
                android:text="Ver\nAlunos"
                android:backgroundTint="#546E7A"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnMenuVerCursos"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:text="Ver\nCursos"
                android:backgroundTint="#546E7A"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>