<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtNomeCursoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome do Curso"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:id="@+id/txtDuracaoCursoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Duração: 5 semestres"
            android:textSize="13sp"
            android:textColor="#666666" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtTurnoCursoItem"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Noturno"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnEditarCursoItem"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:text="E"
            android:textSize="12sp"
            android:padding="0dp"
            android:backgroundTint="#E5BE40"
            android:textColor="#FFFFFF"
            android:layout_marginRight="4dp" />

        <Button
            android:id="@+id/btnExcluirCursoItem"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:text="X"
            android:textSize="12sp"
            android:padding="0dp"
            android:backgroundTint="#FF5252"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>